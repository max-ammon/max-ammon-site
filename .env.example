# Copy to .env and fill in. .env is git-ignored and is NOT baked into the Docker
# image — compose injects it at runtime (env_file). On the VPS, create this file
# next to docker-compose.yml.

# Local dev only. In Docker these three are set by docker-compose.yml
# (NODE_ENV=production, HOST=0.0.0.0), so you can leave them as-is here.
NODE_ENV=development
HOST=127.0.0.1
PORT=3000

# REQUIRED. Signs session cookies. Generate a long random value:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Keep it stable — changing it logs everyone out. Reuse the one from your
# backup if you want existing logins to survive the move to the VPS.
SESSION_SECRET=change-me

# Contact-form email (optional). Until set, messages are still saved and shown
# in the admin inbox — they're just not emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Max Ammon site <no-reply@max-ammon.com>"
MAIL_TO=3d@max-ammon.com

# NOTE: in production the app sets secure cookies + trusts one proxy hop, so it
# must sit behind HTTPS that forwards X-Forwarded-Proto (any normal reverse
# proxy does). Plain-HTTP production access will break login.
